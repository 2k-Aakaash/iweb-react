{
  "manifest_version": 3,
  "name": "iWeb React",
  "version": "1.0.0",
  "description": "iWeb: Individualized Web Interface - React Edition.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.met.no/*",
    "https://nominatim.openstreetmap.org/*",
    "https://ipapi.co/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_icon": {
      "16": "images/png/iWeb Logo 16.png",
      "48": "images/png/iWeb Logo 48.png",
      "128": "images/png/iWeb Logo 128.png"
    }
  },
  "icons": {
    "16": "images/png/iWeb Logo 16.png",
    "48": "images/png/iWeb Logo 48.png",
    "128": "images/png/iWeb Logo 128.png"
  }
}
